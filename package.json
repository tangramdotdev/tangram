{
	"private": true,
	"workspaces": [
		"packages/clients/js",
		"packages/js",
		"packages/typescript",
		"packages/vscode"
	],
	"scripts": {
		"build": "tg run -b . -- build",
		"build:all": "tg run -b . -- build --all-features",
		"canary": "tg build .#release && gh release upload canary .tangram/release/* --clobber && git tag canary -f && git push origin tag canary -f",
		"clean": "rm -rf .tangram node_modules target",
		"cloud:up": "nu scripts/cloud/up.nu",
		"cloud:down": "nu scripts/cloud/down.nu",
		"cloud:init": "nu scripts/cloud/init.nu",
		"cloud:deinit": "nu scripts/cloud/deinit.nu",
		"cloud:server": "nu scripts/cloud/server.nu",
		"cloud:runner": "nu scripts/cloud/runner.nu",
		"test": "nu packages/cli/test.nu $@ && cargo nextest run --no-fail-fast --workspace",
		"tg": "tg run -b . -- run --all-features -c .config/tangram/config.json -d .tangram -m client",
		"tgr": "tg run -b . -- run --release -c .config/tangram/config.json -d .tangram -m client",
		"tgrs": "tg run -b . -- run --release -c .config/tangram/config.json -d .tangram -m server",
		"tgrsx": "tg run -b . -- run --release -c .config/tangram/config.json -d .tangram -m server run -b",
		"tgrx": "tg run -b . -- run -c .config/tangram/config.json -d .tangram -m client run -b",
		"tgs": "tg run -b . -- run -c .config/tangram/config.json -d .tangram -m server",
		"tgsx": "tg run -b . -- run -c .config/tangram/config.json -d .tangram -m server run -b",
		"tgx": "tg run -b . -- run -c .config/tangram/config.json -d .tangram -m client run -b"
	},
	"dependencies": {
		"@types/bun": "^1.3.9",
		"@typescript/native-preview": "^7.0.0-dev.20260225.1",
		"esbuild": "^0.27.3",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"typescript": "^5.9.3"
	}
}
