{
	"private": true,
	"workspaces": [
		"packages/clients/js",
		"packages/js",
		"packages/typescript",
		"packages/vscode"
	],
	"scripts": {
		"canary": "bun scripts/canary.ts",
		"check": "cargo clippy --all-features --all-targets --workspace && bun run --parallel --filter \"*\" check",
		"clean": "rm -rf .tangram node_modules target",
		"cloud:up": "nu scripts/cloud/up.nu",
		"cloud:down": "nu scripts/cloud/down.nu",
		"cloud:init": "nu scripts/cloud/init.nu",
		"cloud:deinit": "nu scripts/cloud/deinit.nu",
		"cloud:server": "nu scripts/cloud/server.nu",
		"cloud:runner": "nu scripts/cloud/runner.nu",
		"format": "cargo fmt --all && bun run --parallel --filter \"*\" format",
		"test": "nu packages/cli/test.nu $@ && cargo nextest run --no-fail-fast --workspace && bun run --parallel --filter \"*\" test",
		"tg": "PATH=\"$PWD/target/debug:$PATH\" cargo run --all-features -- -c .config/tangram/config.json -d .tangram -m client",
		"tgr": "PATH=\"$PWD/target/release:$PATH\" cargo run --all-features --release -- -c .config/tangram/config.json -d .tangram -m client",
		"tgrs": "PATH=\"$PWD/target/release:$PATH\" cargo run --all-features --release -- -c .config/tangram/config.json -d .tangram -m server",
		"tgrsx": "PATH=\"$PWD/target/release:$PATH\" cargo run --all-features --release -- -c .config/tangram/config.json -d .tangram -m server run -b",
		"tgrx": "PATH=\"$PWD/target/debug:$PATH\" cargo run --all-features -- -c .config/tangram/config.json -d .tangram -m client run -b",
		"tgs": "PATH=\"$PWD/target/debug:$PATH\" cargo run --all-features -- -c .config/tangram/config.json -d .tangram -m server",
		"tgsx": "PATH=\"$PWD/target/debug:$PATH\" cargo run --all-features -- -c .config/tangram/config.json -d .tangram -m server run -b",
		"tgx": "PATH=\"$PWD/target/debug:$PATH\" cargo run --all-features -- -c .config/tangram/config.json -d .tangram -m client run -b"
	},
	"dependencies": {
		"@types/bun": "^1.3.11",
		"@typescript/native-preview": "^7.0.0-dev.20260401.1",
		"esbuild": "^0.27.5",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"typescript": "^6.0.2"
	}
}
